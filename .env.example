# ─── Server ────────────────────────────────────────────────
NODE_ENV=development            # development | production
PORT=3001                       # API port (web runs on 3000)
HOST=localhost                  # 0.0.0.0 in production behind reverse proxy
BASE_URL=http://localhost:3001
WEB_ORIGIN=http://localhost:3000

# ─── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://relay:relay@localhost:5432/relay

# ─── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ───────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=replace_me_with_a_64_byte_hex_string_for_local_dev_only_never_in_prod
JWT_REFRESH_SECRET=replace_me_with_a_different_64_byte_hex_string_for_local_dev_only
JWT_ACCESS_EXPIRY=900           # seconds (15 min)
JWT_REFRESH_EXPIRY=604800       # seconds (7 days)

# ─── Cookies ───────────────────────────────────────────────
# Generate with: openssl rand -hex 32
COOKIE_SECRET=replace_me_with_a_32_byte_hex_string

# ─── MinIO (S3-compatible) ─────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false             # true in production
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_MEDIA=relay-media
MINIO_REGION=us-east-1

# ─── Media ─────────────────────────────────────────────────
MEDIA_SIGNED_URL_EXPIRY=30      # seconds (short window for ephemeral)
MEDIA_MAX_SIZE_MB=100

# ─── FFmpeg ────────────────────────────────────────────────
FFMPEG_BIN=                     # leave blank — auto-detected (defaults to "ffmpeg" on $PATH)

# ─── Voice transcription (openai-whisper CLI) ───────────────
WHISPER_BIN=whisper             # path to whisper CLI (defaults to "whisper" on $PATH)
WHISPER_MODEL=medium            # medium (cached) | large-v3 (prod)
VOICE_MAX_DURATION_MS=300000    # 5 min
VOICE_TRANSCRIBE_CONCURRENCY=2  # keep low on small VPS (CPU-bound)

# ─── Video transcoding (Phase 6B) ──────────────────────────
VIDEO_TRANSCODE_CONCURRENCY=1   # 1 on small VPS to avoid CPU saturation
VIDEO_H264_CRF=21               # 20–22 = ~85–95% perceptual quality
VIDEO_H264_PRESET=medium        # ultrafast → slower trades CPU for file size

# ─── Discord push notifications (temporary, pre-APNs) ──────
DISCORD_WEBHOOK_URL=            # https://discord.com/api/webhooks/...
DISCORD_ALERT_USER_ID=          # your UUID from the DB — alerts only this recipient

# ─── Web (Next.js) ─────────────────────────────────────────
API_URL=http://localhost:3001
WS_URL=ws://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
