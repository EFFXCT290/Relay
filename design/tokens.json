{
  "$schema": "https://design-tokens.org/draft-1/schema.json",
  "meta": {
    "name": "Relay",
    "version": "0.1.0",
    "tagline": "A secure way to message.",
    "mood": "nocturnal-signal",
    "moodReference": "Vehicle dashboard at night: instrument-black housing, Blue 500 indicator LED, soft amber and green secondary lights.",
    "canonicalMode": "dark",
    "supports": ["dark", "light"]
  },
  "color": {
    "brand": {
      "signal": { "value": "#3B82F6", "role": "primary brand, sent bubble, focus ring" },
      "signalHover": { "value": "#2563EB", "role": "primary hover/active" },
      "signalSubtle": { "value": "rgba(59,130,246,0.40)", "role": "typing indicator, focus glow" },
      "readReceipt": { "value": "#BFDBFE", "role": "read-receipt text under bubble" }
    },
    "status": {
      "online": { "value": "#22C55E" },
      "warning": { "value": "#F59E0B" },
      "alert": { "value": "#EF4444", "role": "screenshot/record capture detected" },
      "info": { "value": "#3B82F6" }
    },
    "dark": {
      "bg": "#0A0A0B",
      "panel": "#141416",
      "raised": "#1C1C20",
      "hairline": "rgba(255,255,255,0.07)",
      "hairlineStrong": "rgba(255,255,255,0.12)",
      "text": {
        "primary": "#F4F4F5",
        "secondary": "#A1A1AA",
        "muted": "#52525B"
      },
      "bubbleReceived": "#1C1C20",
      "bubbleSent": "#3B82F6",
      "bubbleSentText": "#FFFFFF"
    },
    "light": {
      "bg": "#FFFFFF",
      "panel": "#F4F4F5",
      "raised": "#FAFAFA",
      "hairline": "rgba(10,10,11,0.08)",
      "hairlineStrong": "rgba(10,10,11,0.14)",
      "text": {
        "primary": "#0A0A0B",
        "secondary": "#52525B",
        "muted": "#A1A1AA"
      },
      "bubbleReceived": "#F4F4F5",
      "bubbleSent": "#3B82F6",
      "bubbleSentText": "#FFFFFF"
    }
  },
  "type": {
    "family": {
      "display": "\"Manrope\", system-ui, sans-serif",
      "body": "\"Inter\", system-ui, sans-serif",
      "mono": "\"Geist Mono\", ui-monospace, SFMono-Regular, monospace"
    },
    "weight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700,
      "extrabold": 800
    },
    "size": {
      "display-2xl": "56px",
      "display-xl": "40px",
      "display-lg": "32px",
      "display-md": "24px",
      "display-sm": "20px",
      "body-lg": "17px",
      "body-md": "15px",
      "body-sm": "13px",
      "mono-md": "13px",
      "mono-sm": "12px",
      "eyebrow": "12px"
    },
    "lineHeight": {
      "display": "1.05",
      "heading": "1.15",
      "body": "1.45",
      "tight": "1.25"
    },
    "letterSpacing": {
      "display": "-0.02em",
      "body": "0",
      "eyebrow": "0.12em"
    }
  },
  "space": {
    "0": "0px",
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "8": "32px",
    "10": "40px",
    "12": "48px",
    "16": "64px",
    "20": "80px",
    "24": "96px"
  },
  "radius": {
    "sm": "8px",
    "md": "12px",
    "lg": "20px",
    "bubble": "28px",
    "pill": "999px"
  },
  "shadow": {
    "card": "0 1px 0 rgba(255,255,255,0.04) inset, 0 0 0 1px rgba(255,255,255,0.07)",
    "raised": "0 8px 24px rgba(0,0,0,0.35), 0 0 0 1px rgba(255,255,255,0.07)",
    "focus": "0 0 0 3px rgba(59,130,246,0.40)"
  },
  "breakpoint": {
    "sm": "640px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px",
    "2xl": "1536px"
  },
  "motion": {
    "duration": { "fast": "120ms", "base": "200ms", "slow": "320ms" },
    "easing": { "out": "cubic-bezier(0.2, 0.7, 0.2, 1)", "inOut": "cubic-bezier(0.65, 0, 0.35, 1)" }
  }
}
