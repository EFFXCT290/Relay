// Relay — unified schema (v1.0 + v1.1 addendum)
// Source of truth: Documentation/API_DOCUMENTATION.md + RELAY_API_ADDENDUM_v1.1.md
// v1.1 supersedes v1.0 for: Media model (quality/status), Read receipts, Last seen.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ────────────────────────────────────────────────────────────────────────────
//  Identity
// ────────────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  username     String   @unique @db.VarChar(30)
  passwordHash String
  passwordSalt String   @db.Char(64) // 32 bytes hex
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sentMessages  Message[]        @relation("SentMessages")
  conversations Participant[]
  notifications Notification[]
  uploadedMedia Media[]
  reads         MessageRead[]
  reactions     Reaction[]
  presence      UserPresence?

  @@index([username])
}

model UserPresence {
  userId     String   @id
  lastSeenAt DateTime @updatedAt
  isOnline   Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ────────────────────────────────────────────────────────────────────────────
//  Conversations & messages
// ────────────────────────────────────────────────────────────────────────────

model Conversation {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants Participant[]
  messages     Message[]
}

model Participant {
  id             String    @id @default(uuid())
  userId         String
  conversationId String
  joinedAt       DateTime  @default(now())
  acceptedAt     DateTime?

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([userId, conversationId])
  @@index([conversationId])
}

model Message {
  id             String      @id @default(uuid())
  conversationId String
  senderId       String
  type           MessageType
  body           String?
  replyToId      String?
  isEdited       Boolean     @default(false)
  editedAt       DateTime?
  isDeleted      Boolean     @default(false)
  deletedAt      DateTime?
  deliveredAt    DateTime?
  clientMessageId String?                    // client-generated UUID for idempotent sends
  createdAt      DateTime    @default(now())

  conversation  Conversation       @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender        User               @relation("SentMessages", fields: [senderId], references: [id])
  replyTo       Message?           @relation("Replies", fields: [replyToId], references: [id])
  replies       Message[]          @relation("Replies")
  attachments   MessageAttachment[]
  reads         MessageRead[]
  reactions     Reaction[]
  embed         MessageEmbed?

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@unique([senderId, clientMessageId])
}

model MessageEmbed {
  id          String   @id @default(uuid())
  messageId   String   @unique
  url         String
  title       String?
  description String?
  imageUrl    String?
  siteName    String?
  faviconUrl  String?
  type        String?
  provider    String?
  createdAt   DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model Reaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  emoji     String   @db.VarChar(16)
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([messageId, userId])   // one reaction per user per message; second tap toggles
  @@index([messageId])
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
}

model MessageRead {
  id        String   @id @default(uuid())
  messageId String
  readerId  String
  readAt    DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  reader  User    @relation(fields: [readerId], references: [id])

  @@unique([messageId, readerId])
  @@index([messageId])
  @@index([readerId])
}

// ────────────────────────────────────────────────────────────────────────────
//  Media (Phase 1 — upload-first, attach-to-message via MessageAttachment)
// ────────────────────────────────────────────────────────────────────────────

model Media {
  id              String   @id @default(cuid())
  uploaderId      String
  storageKey      String   @unique
  blurStorageKey  String?
  thumbStorageKey String?
  mimeType        String
  sizeBytes       Int
  width           Int?
  height          Int?
  blurWidth       Int?
  blurHeight      Int?
  thumbWidth      Int?
  thumbHeight     Int?
  status          String   @default("ready")  // "processing" | "ready" | "failed"
  clientUploadId  String?  @unique            // client-generated UUID for idempotent re-uploads
  // Voice-note fields (kind = "voice"). durationMs is supplied by the recorder.
  // transcript holds the structured Whisper result {segments,fullText,primaryLanguage};
  // transcriptStatus tracks the async transcription job independently of `status`.
  durationMs       Int?
  transcript       Json?
  transcriptStatus String?                    // "pending" | "ready" | "failed" (null for non-voice)
  createdAt       DateTime @default(now())

  uploader    User                @relation(fields: [uploaderId], references: [id])
  attachments MessageAttachment[]
}

model MessageAttachment {
  id        String   @id @default(cuid())
  messageId String
  mediaId   String
  type      String   // "image"
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  media   Media   @relation(fields: [mediaId], references: [id])

  @@index([messageId])
}

// ────────────────────────────────────────────────────────────────────────────
//  Notifications & auth blocklist
// ────────────────────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  payload   Json
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

enum NotificationType {
  SYSTEM_ALERT
  MESSAGE_RECEIVED
}

model JtiBlocklist {
  jti       String   @id
  expiresAt DateTime

  @@index([expiresAt])
}

// ────────────────────────────────────────────────────────────────────────────
//  Realtime event outbox (Phase 4.3 reconnect replay)
// ────────────────────────────────────────────────────────────────────────────
// One row per (event, recipient). Rows are written before socket emit so no
// event can be lost between "sent" and "recorded". ackedAt is stamped when
// the recipient confirms delivery; only null-ackedAt rows appear in replay.
// Cleanup of old acked rows is a background job (separate from this schema).
model EventOutbox {
  id             String    @id @default(uuid())
  eventId        String    @unique
  eventName      String
  conversationId String?   // scopes replay to a single thread; null = user-global event
  payload        Json
  recipientId    String
  createdAt      DateTime  @default(now())
  ackedAt        DateTime?

  // id tiebreaks millisecond collisions → deterministic replay order under burst load.
  @@index([recipientId, ackedAt, createdAt, id])
}
