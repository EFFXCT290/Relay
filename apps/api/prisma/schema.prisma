// Relay — unified schema (v1.0 + v1.1 addendum)
// Source of truth: Documentation/API_DOCUMENTATION.md + RELAY_API_ADDENDUM_v1.1.md
// v1.1 supersedes v1.0 for: Media model (quality/status), Read receipts, Last seen.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ────────────────────────────────────────────────────────────────────────────
//  Identity
// ────────────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  username     String   @unique @db.VarChar(30)
  passwordHash String
  passwordSalt String   @db.Char(64) // 32 bytes hex
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sentMessages  Message[]      @relation("SentMessages")
  conversations Participant[]
  notifications Notification[]
  uploadedMedia Media[]
  reads         MessageRead[]
  reactions     Reaction[]
  presence      UserPresence?

  @@index([username])
}

// Durable "last seen" history. The presence service is the SOLE writer of
// lastSeenAt and sets it explicitly (no @updatedAt) — so the timestamp can't be
// re-stamped by unrelated row updates. @default(now()) is an INSERT-only fallback
// for the NOT NULL column (never fires on UPDATE, so it can't re-stamp). isOnline
// is written best-effort for debugging but is NEVER read for status; online is
// derived from the Redis heartbeat key. See apps/api/src/modules/presence/.
model UserPresence {
  userId     String   @id
  lastSeenAt DateTime @default(now())
  isOnline   Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ────────────────────────────────────────────────────────────────────────────
//  Conversations & messages
// ────────────────────────────────────────────────────────────────────────────

model Conversation {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants Participant[]
  messages     Message[]
}

model Participant {
  id             String    @id @default(uuid())
  userId         String
  conversationId String
  joinedAt       DateTime  @default(now())
  acceptedAt     DateTime?

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([userId, conversationId])
  @@index([conversationId])
}

model Message {
  id              String      @id @default(uuid())
  conversationId  String
  senderId        String
  type            MessageType
  body            String?
  replyToId       String?
  isEdited        Boolean     @default(false)
  editedAt        DateTime?
  isDeleted       Boolean     @default(false)
  deletedAt       DateTime?
  deliveredAt     DateTime?
  clientMessageId String? // client-generated UUID for idempotent sends
  createdAt       DateTime    @default(now())

  conversation Conversation        @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User                @relation("SentMessages", fields: [senderId], references: [id])
  replyTo      Message?            @relation("Replies", fields: [replyToId], references: [id])
  replies      Message[]           @relation("Replies")
  attachments  MessageAttachment[]
  reads        MessageRead[]
  reactions    Reaction[]
  embed        MessageEmbed?

  @@unique([senderId, clientMessageId])
  @@index([conversationId, createdAt])
  @@index([senderId])
}

model MessageEmbed {
  id          String   @id @default(uuid())
  messageId   String   @unique
  url         String
  title       String?
  description String?
  imageUrl    String?
  siteName    String?
  faviconUrl  String?
  type        String?
  provider    String?
  createdAt   DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model Reaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  emoji     String   @db.VarChar(16)
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([messageId, userId]) // one reaction per user per message; second tap toggles
  @@index([messageId])
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
}

model MessageRead {
  id        String   @id @default(uuid())
  messageId String
  readerId  String
  readAt    DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  reader  User    @relation(fields: [readerId], references: [id])

  @@unique([messageId, readerId])
  @@index([messageId])
  @@index([readerId])
}

// ────────────────────────────────────────────────────────────────────────────
//  Media (Phase 1 — upload-first, attach-to-message via MessageAttachment)
// ────────────────────────────────────────────────────────────────────────────

model Media {
  id               String  @id @default(cuid())
  uploaderId       String
  storageKey       String  @unique
  blurStorageKey   String?
  thumbStorageKey  String?
  mimeType         String
  sizeBytes        Int
  width            Int?
  height           Int?
  blurWidth        Int?
  blurHeight       Int?
  thumbWidth       Int?
  thumbHeight      Int?
  status           String  @default("ready") // "processing" | "ready" | "failed"
  clientUploadId   String? @unique // client-generated UUID for idempotent re-uploads
  // Voice-note fields (kind = "voice"). durationMs is supplied by the recorder.
  // transcript holds the structured Whisper result {segments,fullText,primaryLanguage};
  // transcriptStatus tracks the async transcription job independently of `status`.
  durationMs       Int?
  transcript       Json?
  transcriptStatus String? // "pending" | "ready" | "failed" (null for non-voice)

  // ── Phase 6B (video integration) ──────────────────────────────────────────
  // kind classifies the asset for routing the right pipeline; legacy rows are
  // null and treated as "image" by readers. deliveryMode is the user's choice
  // (or auto-promoted to LSS for HEVC/DNG); isLss mirrors it as a fast badge
  // flag. isHevcSource records the probed source codec for the auto-LSS rule.
  // Variants + tasks live in their own tables; manifest.json in MinIO remains
  // the canonical source of truth — these columns are denormalized for queries.
  kind         MediaKind? // null = legacy (pre-6B); reader defaults to image
  deliveryMode MediaDeliveryMode @default(OPTIMIZED)
  isLss        Boolean           @default(false)
  isHevcSource Boolean           @default(false)

  createdAt DateTime @default(now())

  uploader    User                  @relation(fields: [uploaderId], references: [id])
  attachments MessageAttachment[]
  variants    MediaVariant[]
  tasks       MediaProcessingTask[]
}

// ────────────────────────────────────────────────────────────────────────────
//  Phase 6B — normalized variant + processing-task model
// ────────────────────────────────────────────────────────────────────────────
// Replaces per-derivative status columns on Media. Each generated rendition is
// a MediaVariant row (one per type), and each async unit of work is a
// MediaProcessingTask row with its own state machine. Workers are stateless:
// they derive every storage key from (mediaId, type) and write results here +
// into the manifest.

enum MediaKind {
  IMAGE
  VIDEO
  VOICE
}

enum MediaDeliveryMode {
  OPTIMIZED
  LSS
}

enum MediaVariantType {
  ORIGINAL
  OPTIMIZED // image display webp/avif, or video streaming mp4
  POSTER // video poster frame
  PREVIEW // animated video preview
  THUMBNAIL // sm/md/lg chat-list thumbs (label distinguishes size)
  WAVEFORM // voice waveform json
}

enum MediaTaskType {
  TRANSCODE
  THUMBNAIL
  POSTER
  WAVEFORM
  TRANSCRIPT
}

enum MediaTaskState {
  PENDING
  PROCESSING
  READY
  FAILED
}

model MediaVariant {
  id         String           @id @default(cuid())
  mediaId    String
  type       MediaVariantType
  label      String           @default("") // disambiguates same-type variants (thumb_sm/md/lg, stream_720p); "" for singletons
  storageKey String           @unique
  mimeType   String
  codec      String?
  width      Int?
  height     Int?
  bitrate    Int? // bits/sec, video only
  sizeBytes  Int?
  createdAt  DateTime         @default(now())

  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([mediaId, type, label])
  @@index([mediaId])
}

model MediaProcessingTask {
  id        String         @id @default(cuid())
  mediaId   String
  type      MediaTaskType
  state     MediaTaskState @default(PENDING)
  attempts  Int            @default(0)
  error     String? // last failure detail, truncated
  startedAt DateTime?
  endedAt   DateTime?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([mediaId, type])
  @@index([mediaId])
  @@index([state])
}

model MessageAttachment {
  id        String   @id @default(cuid())
  messageId String
  mediaId   String
  type      String // "image"
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  media   Media   @relation(fields: [mediaId], references: [id])

  @@index([messageId])
}

// ────────────────────────────────────────────────────────────────────────────
//  Notifications & auth blocklist
// ────────────────────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  payload   Json
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

enum NotificationType {
  SYSTEM_ALERT
  MESSAGE_RECEIVED
}

model JtiBlocklist {
  jti       String   @id
  expiresAt DateTime

  @@index([expiresAt])
}

// ────────────────────────────────────────────────────────────────────────────
//  Realtime event outbox (Phase 4.3 reconnect replay)
// ────────────────────────────────────────────────────────────────────────────
// One row per (event, recipient). Rows are written before socket emit so no
// event can be lost between "sent" and "recorded". ackedAt is stamped when
// the recipient confirms delivery; only null-ackedAt rows appear in replay.
// Cleanup of old acked rows is a background job (separate from this schema).
model EventOutbox {
  id             String    @id @default(uuid())
  eventId        String    @unique
  eventName      String
  conversationId String? // scopes replay to a single thread; null = user-global event
  payload        Json
  recipientId    String
  createdAt      DateTime  @default(now())
  ackedAt        DateTime?

  // id tiebreaks millisecond collisions → deterministic replay order under burst load.
  @@index([recipientId, ackedAt, createdAt, id])
}
